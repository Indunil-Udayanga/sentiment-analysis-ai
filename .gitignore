# Trained model artifacts (large / regenerable from the notebook — don't commit)
backend/app/artifacts/*.pth
backend/app/artifacts/*.joblib
backend/app/artifacts/*.json
!backend/app/artifacts/.gitkeep

### --- Jupyter ---
.ipynb_checkpoints/

